    <script type="text/javascript" class="init">



var editor; // use a global for the submit and return data rendering in the examples

$(document).ready(function() {

table=$('#example').DataTable( {
    ajax: "@Url.Action("GetAjaxData", "SalesOrder")",
        "order": [[6, "desc"]],
        stateSave: true,
        "language": {
            "lengthMenu": '_MENU_ rows',
            "search": '<i class="fa fa-search"></i>',
            "searchPlaceholder": "search",
            "paginate": {
                "previous": '<i class="fa fa-angle-left"></i>',
                "next": '<i class="fa fa-angle-right"></i>'
            }
        },
		columns: [
            { data: "VoucherDate" },
            { data: "VoucherNumber" },
            { data: "PartyName" },
            { data: "TotalAmount" },
            { data: "DispStatus" },
            { data: "VoucherId", "visible": false },
			{

                mRender: function (data, type, row) {
                    return '<a href="@Url.Action("Form", "Invoice")/' + row["BILLMID"] + '"   class="editor_edit btn btn-warning btn-sm hide" ><i class="glyphicon glyphicon-pencil"></i></a>&nbsp;<a href="@Url.Action("PrintView", "Invoice")/' + row["VoucherId"] + '-0"   class="editor_print btn btn-success btn-sm hide"  target="_blank" ><i class="glyphicon glyphicon-print"></i></a>&nbsp;<a href="@Url.Action("PrintView", "Invoice")/' + row["VoucherId"] + '-1"   class="new_editor_print btn btn-warning btn-sm hide"  target="_blank" ><i class="glyphicon glyphicon-print"></i></a>&nbsp;<a href="#" id="' + row["VoucherId"] + '\" class="editor_remove btn btn-danger btn-sm" >Tally</a>'
			    }
			}
		]
    });


//alert("4");

            $("#from").datepicker({
                defaultDate: "+1w",
                changeMonth: true,
                numberOfMonths: 3,
                dateFormat: 'dd-mm-yy',
                onClose: function (selectedDate) {
                    $("#to").datepicker("option", "minDate", selectedDate);
                }
            });
            $("#to").datepicker({
                defaultDate: "+1w",
                changeMonth: true,
                numberOfMonths: 3,
                dateFormat: 'dd-mm-yy',
                onClose: function (selectedDate) {
                    $("#from").datepicker("option", "maxDate", selectedDate);
                }
            });





    $(document).on("click", "a.editor_remove", function () {

        var idx = $(this).attr('id');
        var base = window.location.origin;
var bad = 0;

if (bad == 0) {

    swal({
        title: "Are you sure?",
        text: "Are you sure that you want to sync this Sales Order to Tally?",
        type: "warning",
        confirmButtonText: "Yes, Sync",
        showCancelButton: true,
        cancelButtonText: "No",
        showCloseButton: true
    }).then(function (result) {

        if (result.value) {
            //alert(idx);
            $.ajax({
                type: 'POST',
                url: '@Url.Action("SalesOrderXML", "SalesOrder")',
                data: {
                    id: idx          // Sales Order ID
                },
                success: function (data) {

                    if (data.status === true) {

                        swal({
                            title: "Success",
                            text: data.message || "Sales Order synced successfully",
                            type: "success"
                        }).then(function () {
                            window.location.href = '@Url.Action("Index", "SalesOrder")';
                        });

                    } else {

                        swal({
                            title: "Failed",
                            text: data.message || "Sales Order sync failed",
                            type: "error"
                        });
                    }
                },
                error: function (ex) {

                    swal({
                        title: "Error",
                        text: "Server error while syncing Sales Order",
                        type: "error"
                    });
                }
            });

        } else {
            return false;
        }
    });
}


        return false;
    });




