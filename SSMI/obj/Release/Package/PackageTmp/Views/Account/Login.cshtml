@model SSMI.Models.LoginViewModel
@{
    ViewBag.Title = "Login";
    //Layout = "~/Views/Shared/_Layout.cshtml";
    Layout = "~/Views/Shared/_Login.cshtml";
}

<style>
    .form-signin {
        margin: 0 auto;
        max-width: 330px;
        padding: 15px;
    }




    * {
        -webkit-box-sizing: border-box;
        -moz-box-sizing: border-box;
        box-sizing: border-box;
        outline: none;
    }

    body {
        background: url('../../Content/images/bg.png') no-repeat center center fixed;
        -webkit-background-size: cover;
        -moz-background-size: cover;
        -o-background-size: cover;
        background-size: cover;
    }

    .login-form {
        font: 16px/2em Lato, serif;
        margin: 100px auto;
        max-width: 400px;
    }

    form[role=login] {
        color: #5d5d5d;
        background: #f2f2f2;
        padding: 26px;
        border-radius: 10px;
        -moz-border-radius: 10px;
        -webkit-border-radius: 10px;
    }

        form[role=login] img {
            display: block;
            margin: 0 auto;
            margin-bottom: 35px;
        }

        form[role=login] input,
        form[role=login] button {
            font-size: 18px;
            margin: 16px 0;
        }

        form[role=login] > div {
            text-align: center;
        }

    .form-links {
        text-align: center;
        margin-top: 1em;
        margin-bottom: 50px;
    }

        .form-links a {
            color: #fff;
        }
</style>

<section class="container">

    <section class="login-form">


        <div class="container-fluid">

            <!-- Page Heading -->
            <div class="row">
                <div class="col-lg-12">

                </div>
            </div>
            <!-- /.row -->

            @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "form-signin", role = "login" }))
            {
                @Html.AntiForgeryToken()
                <img src="~/Content/images/logo.png" class="img-responsive" alt="" />
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                @Html.ValidationMessageFor(m => m.COMPID)
                @Html.DropDownList("COMPID", null, new { @class = "form-control hide" })

                @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", value = "", placeholder = "UserName" })
                @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger" })

                @Html.PasswordFor(m => m.Password, new { @class = "form-control", value = "", placeholder = "Password" })
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                @Html.DropDownList("COMPYID", null, new { @class = "form-control hide" })

                @*@Html.TextBoxFor(m => m.LDATE, new { @class = "form-control LDATE datepicker", @id = "LDATE", @Value = @System.Web.HttpContext.Current.Session["LDATE"], @data_Val = false })*@
                @Html.TextBoxFor(m => m.LDATE, new { @class = "form-control LDATE", @id = "LDATE", @Value = @System.Web.HttpContext.Current.Session["LDATE"], @data_Val = false })

                @*<label class="checkbox">
                        @Html.CheckBoxFor(m => m.RememberMe)
                        Remember me
                    </label>*@
                @*<input type="text" class="span2" value="27-01-2018" data-date-format="dd-mm-yyyy" id="dp2" Value = @System.Web.HttpContext.Current.Session["LDATE"]>*@
                <input type="submit" value="Log in" class="btn btn-lg btn-primary btn-block" />
            }
             <div class="form-links">
                <a href="http://shefa.co.in/" target="_blank">www.shefa.co.in   </a>
            </div>
        </div>

    </section>
</section>

<!-- /.container-fluid -->
