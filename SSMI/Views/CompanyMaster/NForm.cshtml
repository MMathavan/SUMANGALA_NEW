                                                            <tr class="item-row">
                                                                <td class="hide">
                                                                    <input type="text" value="@details.COMPDID" id="COMPDID" class="COMPDID" name="COMPDID" />
                                                                </td>
                                                                <td class="col-lg-6">
                                                                    <input class="COMPPONAME form-control" id="COMPPONAME" name="COMPPONAME" value="@details.COMPPONAME" />
                                                                </td>
                                                                <td class="col-lg-6">
                                                                    @*<input class="COMPPONAME form-control" id="COMPPONAME" name="COMPPONAME" value="@details.COMPPONAME" />*@
                                                                    <textarea name="COMPPOADDR" class="COMPPOADDR form-control" id="COMPPOADDR" rows="5">@details.COMPPOADDR</textarea>
                                                                </td>
                                                                <td> <a class="btn btn-danger" id="del_detail"> Delete</a> </td>
                                                            </tr>

                                                        }
                                                    }
                                                    else
                                                    {
                                                        <tr class="item-row">
                                                            <td class="hide">
                                                                <input type="text" value="0" id="COMPDID" class="COMPDID" name="COMPDID" />
                                                            </td>
                                                            <td class="col-lg-6">
                                                                <input class="COMPPONAME form-control" id="COMPPONAME" name="COMPPONAME" />
                                                            </td>
                                                            <td class="col-lg-6">
                                                                <textarea name="COMPPOADDR" class="COMPPOADDR form-control" id="COMPPOADDR" rows="5" ></textarea>
                                                            </td>
                                                            <td><a class="btn btn-danger" id="del_detail"> Delete</a></td>
                                                        </tr>
                                                    }

                                                }
                                                else
                                                {
                                                    <tr class="item-row">
                                                        <td class="hide">
                                                            <input type="text" value="0" id="COMPDID" class="COMPDID" name="COMPDID" />
                                                        </td>
                                                        <td class="col-lg-6">
                                                            <input class="COMPPONAME form-control" id="COMPPONAME" name="COMPPONAME" />
                                                        </td>
                                                        <td class="col-lg-6">
                                                            <textarea name="COMPPOADDR" class="COMPPOADDR form-control" id="COMPPOADDR" rows="5"></textarea>
                                                        </td>
                                                        <td><a class="btn btn-danger" id="del_detail"> Delete</a></td>
                                                    </tr>
                                                }


                                            </tbody>

                                        </table>
                                        <table></table>

                                    </div>
                                </div>
                            </div>



                            <input type="button" name="back" value="Go Back" class="btn btn-primary" onclick="JavaScript:history.back()" />
                            <input type="submit" name="submit" value="Submit" class="btn btn-primary pull-right" />



                        </fieldset>

                    </form>
                </div>
            </div>
        </div>


    </div>
</div>

