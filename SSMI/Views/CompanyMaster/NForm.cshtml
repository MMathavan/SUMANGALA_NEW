        function validate() {

            temp2 = $("#COMPNAME").val();
            if (temp2.trim() == "") { alert("Please Enter the Company Name"); $("#COMPNAME").focus(); return false; }

            temp3 = $("#COMPDNAME").val();
            if (temp3.trim() == "") { alert("Please Enter the Company Display Name"); $("#COMPDNAME").focus(); return false; }

