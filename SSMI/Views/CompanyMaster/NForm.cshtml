@using SSMI.Data;
@model SSMI.Models.Company
@{
    ViewBag.Title = "NForm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="col-lg-12">
    <div class="panel panel-primary">
        <div class="panel-heading">
            <h3 class="panel-title"><i class="fa fa-bar-chart-o fa-fw"></i>  Company Master  <div class="clearfix"> </div></h3>
        </div>

        @Html.Raw(ViewBag.msg)
        <div class="row">
            <div class="col-md-12">
                <div class="panel-body">
                    <form action="@Url.Content("~/CompanyMaster/nsavedata")" method="post" accept-charset="utf-8" id="companymasterform" data-ng-controller="myController" name="companymasterform">


                        @Html.ValidationSummary(true)

                        <fieldset id="CompanyMasterForm_info">


                            <div class="row">
                                <div class="col-md-12">


                                    <div class="col-md-4 hidden">
                                        <div class="form-group">
                                            <label>Primary  </label>
                                            @Html.TextBoxFor(model => Model.masterdata[0].COMPID, new { @class = "form-control  COMPID", @id = "COMPID" })
                                        </div>

                                    </div>
                                </div>
                                <fieldset style="width:100%">

                                    <div class="col-md-12">


                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Name </label>
                                                @Html.TextBoxFor(model => Model.masterdata[0].COMPNAME, new { @class = "form-control  COMPNAME", @id = "COMPNAME" })
                                                @*<input type="text" value="@Model.COMPNAME" name="i_COMPNAME" hidden />*@
                                            </div>

                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Display Name </label>
                                                @Html.TextBoxFor(model => Model.masterdata[0].COMPDNAME, new { @class = "form-control  COMPDNAME", @id = "COMPDNAME" })
                                            </div>

                                        </div>
                                    </div>

                                    <div class="col-md-12">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Address </label>
                                                @Html.TextAreaFor(model => Model.masterdata[0].COMPADDR, new { @class = "form-control  COMPADDR", @id = "COMPADDR", @rows = "5" })
                                            </div>

                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group">
                                                <label>Landline  </label>
                                                @Html.TextBoxFor(model => Model.masterdata[0].COMPPHN1, new { @class = "form-control  COMPPHN1", @id = "COMPPHN1" })
                                            </div>

                                        </div>

                                        <div class="col-md-3">
                                            <div class="form-group">
                                                <label>Landline 1 </label>
                                                @Html.TextBoxFor(model => Model.masterdata[0].COMPPHN2, new { @class = "form-control  COMPPHN2", @id = "COMPPHN2" })
                                            </div>

                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-group">
                                                <label>Mobile  </label>
                                                @Html.TextBoxFor(model => Model.masterdata[0].COMPPHN3, new { @class = "form-control  COMPPHN3", @id = "COMPPHN3" })
                                            </div>

