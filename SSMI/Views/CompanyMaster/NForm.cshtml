            if (temp4.trim() == "") { alert("Please Enter the Company Code"); $("#COMPCODE").focus(); return false; }

            //$('.TRANTID').removeAttr('disabled');

            var bad = 0;
            $('#TDETAIL :text').each(function () {

                switch (this.id) {
                    default:
                        if ($.trim(this.value) == "" && $.trim(this.value) == 0) bad++;
                }
            });

           // alert(bad);

            if (bad < 1)
                return true;
            else {

                alert("Please Enter PO Company Details before save");
                return false;
            }
