@{
    ViewBag.Title = "Home Page";
}

@*<input type="text" class="form-control" id="CNAME" name="CNAME" value="@ViewBag.CNAME">*@

<div class="container-fluid">

    <!-- Page Heading -->
    <div class="row">
        <div class="col-lg-12">
            @*<h1 class="page-header">
                    Dashboard <small>Statistics Overview</small>
                </h1>*@
            <ol class="breadcrumb">
                <li class="active">
                    <i class="fa fa-dashboard"></i>  Dashboard ( @Session["BRNCHNAME"] )
                </li>
            </ol>
        </div>
    </div>
    <!-- /.row -->

    <style>
        .home-dashboard-hero {
            border-radius: 14px;
            padding: 26px 28px;
            background: linear-gradient(135deg, #5b7cfa 0%, #8a5ad6 100%);
            color: #fff;
            margin-bottom: 18px;
        }

        .home-dashboard-wrap {
            width: 100%;
            max-width: none;
            margin-left: 0;
            margin-right: 0;
            padding-left: 15px;
            padding-right: 15px;
        }

        @@media (min-width: 1200px) {
            .home-dashboard-wrap {
                padding-left: 5cm;
                padding-right: 5cm;
            }
        }

        .home-dashboard-hero h2 {
            margin: 0;
            font-weight: 700;
        }

        .home-stat-card {
            background: #fff;
            border-radius: 12px;
            padding: 14px 16px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
            border: 1px solid rgba(0,0,0,0.06);
            margin-bottom: 16px;
            min-height: 92px;
        }

        .home-stat-title {
            font-size: 11px;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            color: #6b7280;
            margin-bottom: 6px;
        }

        .home-stat-value {
            font-size: 26px;
            font-weight: 800;
            line-height: 1.1;
            margin: 0;
        }

        .home-stat-sub {
            font-size: 12px;
            color: #9ca3af;
            margin-top: 4px;
        }

        .home-stat-icon {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 18px;
            box-shadow: 0 8px 16px rgba(0,0,0,0.12);
        }
    </style>

    <div class="home-dashboard-wrap">
        <div class="row">
            <div class="col-lg-12">
                <div class="home-dashboard-hero">
                    <h2>Business Dashboard</h2>
                    <p>Welcome back, @ViewBag.CNAME! Here's your complete business overview.</p>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-3 col-md-6">
                <div class="home-stat-card">
                    <div class="row">
                        <div class="col-xs-9">
                            <div class="home-stat-title">Item Group Master</div>
                            <div class="home-stat-value">@ViewBag.ItemGroupCount</div>
                            <div class="home-stat-sub">Total item groups in system</div>
                        </div>
                        <div class="col-xs-3 text-right">
                            <span class="home-stat-icon" style="background:#10b981"><i class="fa fa-sitemap"></i></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="home-stat-card">
                    <div class="row">
                        <div class="col-xs-9">
                            <div class="home-stat-title">Item Master</div>
                            <div class="home-stat-value">@ViewBag.ItemCount</div>
                            <div class="home-stat-sub">Total items in system</div>
                        </div>
                        <div class="col-xs-3 text-right">
                            <span class="home-stat-icon" style="background:#3b82f6"><i class="fa fa-cube"></i></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="home-stat-card">
                    <div class="row">
                        <div class="col-xs-9">
                            <div class="home-stat-title">Unit Master</div>
                            <div class="home-stat-value">@ViewBag.UnitCount</div>
                            <div class="home-stat-sub">Total units in system</div>
                        </div>
                        <div class="col-xs-3 text-right">
                            <span class="home-stat-icon" style="background:#f59e0b"><i class="fa fa-arrows-v"></i></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="home-stat-card">
                    <div class="row">
                        <div class="col-xs-9">
                            <div class="home-stat-title">Customer Master</div>
                            <div class="home-stat-value">@ViewBag.CustomerCount</div>
                            <div class="home-stat-sub">Total customers in system</div>
                        </div>
                        <div class="col-xs-3 text-right">
                            <span class="home-stat-icon" style="background:#8b5cf6"><i class="fa fa-users"></i></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="home-dashboard-wrap" style="margin-top: 8px;">
        <div class="row">
            <div class="col-lg-12">
                <h4 style="margin: 8px 0 12px 0; font-weight: 700;">
                    <span style="display:inline-block; width:3px; height:14px; background:#5b7cfa; border-radius:2px; margin-right:8px; position:relative; top:2px;"></span>
                    Transactions
                </h4>

                <form action="#" method="post" accept-charset="utf-8" id="homeTxnFilterForm" style="margin-bottom: 10px;">
                    <label for="from" style="margin-right:6px;">From Date</label>
                    <input type="text" id="from" name="from" value="@((System.Web.HttpContext.Current.Session["SDATE"] as string) ?? "")" style="width:110px;" />

                    <label for="to" style="margin-left:12px; margin-right:6px;">To Date</label>
                    <input type="text" id="to" name="to" value="@((System.Web.HttpContext.Current.Session["EDATE"] as string) ?? "")" style="width:110px;" />

                    <input type="submit" name="submit" value="Filter" class="btn btn-default btn-sm" style="margin-left:10px; background:#111827; color:#fff; border-color:#111827;" />
                    <button type="submit" name="clear" value="1" class="btn btn-default btn-sm" style="margin-left:6px;">Clear</button>
                </form>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6 col-md-6">
                <div class="home-stat-card" style="border-top: 3px solid #7c3aed;">
                    <div class="row">
                        <div class="col-xs-9">
                            <div class="home-stat-title">Total Sales Order</div>
                            <div class="home-stat-value">@ViewBag.TotalSalesOrder</div>
                            <div class="home-stat-sub">All sales orders</div>
                        </div>
                        <div class="col-xs-3 text-right">
                            <span class="home-stat-icon" style="background:#7c3aed"><i class="fa fa-shopping-cart"></i></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 col-md-6">
                <div class="home-stat-card" style="border-top: 3px solid #3b82f6;">
                    <div class="row">
                        <div class="col-xs-9">
                            <div class="home-stat-title">Total Sales Invoice</div>
                            <div class="home-stat-value">@ViewBag.TotalSalesInvoice</div>
                            <div class="home-stat-sub">All sales invoices</div>
                        </div>
                        <div class="col-xs-3 text-right">
                            <span class="home-stat-icon" style="background:#3b82f6"><i class="fa fa-file-text-o"></i></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="home-dashboard-wrap" style="margin-top: 8px;">
        <div class="row">
            <div class="col-lg-12">
                <h4 style="margin: 8px 0 12px 0; font-weight: 700;">
                    <span style="display:inline-block; width:3px; height:14px; background:#5b7cfa; border-radius:2px; margin-right:8px; position:relative; top:2px;"></span>
                    For Sales Order
                </h4>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6 col-md-6">
                <div class="home-stat-card" style="border-top: 3px solid #f59e0b;">
                    <div class="row">
                        <div class="col-xs-9">
                            <div class="home-stat-title">Sync Tally to Web Server</div>
                            <div class="home-stat-value">@ViewBag.SalesOrderSync0Count</div>
                            <div class="home-stat-sub">Sync status 0</div>
                        </div>
                        <div class="col-xs-3 text-right">
                            <span class="home-stat-icon" style="background:#f59e0b"><i class="fa fa-exchange"></i></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 col-md-6">
                <div class="home-stat-card" style="border-top: 3px solid #10b981;">
                    <div class="row">
                        <div class="col-xs-9">
                            <div class="home-stat-title">Sync Web Server to Mobile App</div>
                            <div class="home-stat-value">@ViewBag.SalesOrderSync1Count</div>
                            <div class="home-stat-sub">Sync status 1</div>
                        </div>
                        <div class="col-xs-3 text-right">
                            <span class="home-stat-icon" style="background:#10b981"><i class="fa fa-mobile"></i></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="home-dashboard-wrap" style="margin-top: 8px;">
        <div class="row">
            <div class="col-lg-12">
                <h4 style="margin: 8px 0 12px 0; font-weight: 700;">
                    <span style="display:inline-block; width:3px; height:14px; background:#5b7cfa; border-radius:2px; margin-right:8px; position:relative; top:2px;"></span>
                    For Sales Invoice
                </h4>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6 col-md-6">
                <div class="home-stat-card" style="border-top: 3px solid #f59e0b;">
                    <div class="row">
                        <div class="col-xs-9">
                            <div class="home-stat-title">Sync Tally to Web Server</div>
                            <div class="home-stat-value">@ViewBag.SalesInvoiceSync0Count</div>
                            <div class="home-stat-sub">Sync status 0</div>
                        </div>
                        <div class="col-xs-3 text-right">
                            <span class="home-stat-icon" style="background:#f59e0b"><i class="fa fa-exchange"></i></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 col-md-6">
                <div class="home-stat-card" style="border-top: 3px solid #10b981;">
                    <div class="row">
                        <div class="col-xs-9">
                            <div class="home-stat-title">Sync Web Server to Mobile App</div>
                            <div class="home-stat-value">@ViewBag.SalesInvoiceSync1Count</div>
                            <div class="home-stat-sub">Sync status 1</div>
                        </div>
                        <div class="col-xs-3 text-right">
                            <span class="home-stat-icon" style="background:#10b981"><i class="fa fa-mobile"></i></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Request.IsAuthenticated)
    {
        if (System.Web.HttpContext.Current.Session["Group"].ToString() == "Manager" || System.Web.HttpContext.Current.Session["Group"].ToString() == "Admin")
        {
            <div class="row hide">
                <div class="col-lg-3 col-md-6">
                    <div class="panel panel-danger">
                        <div class="panel-heading">
                            <div class="row">
                                <div class="col-xs-3">
                                    <i class="fa fa-comments fa-5x"></i>
                                </div>
                                <div class="col-xs-9 text-right">
                                    <div class="huge">@ViewBag.POAMT</div>
                                    <div>Total Purchase Order Value</div>
                                </div>
                            </div>
                        </div>
                        <a href="#">
                            <div class="panel-footer">
                                <span class="pull-left">View Details</span>
                                <span class="pull-right"><i class="fa fa-arrow-circle-right"></i></span>
                                <div class="clearfix"></div>
                            </div>
                        </a>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="panel panel-primary">
                        <div class="panel-heading">
                            <div class="row">
                                <div class="col-xs-3">
                                    <i class="fa fa-comments fa-5x"></i>
                                </div>
                                <div class="col-xs-9 text-right">
                                    <div class="huge">@ViewBag.GRNAMT</div>
                                    <div>Total Goods Receipt Value</div>
                                </div>
                            </div>
                        </div>
                        <a href="#">
                            <div class="panel-footer">
                                <span class="pull-left">View Details</span>
                                <span class="pull-right"><i class="fa fa-arrow-circle-right"></i></span>
                                <div class="clearfix"></div>
                            </div>
                        </a>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="panel panel-success">
                        <div class="panel-heading">
                            <div class="row">
                                <div class="col-xs-3">
                                    <i class="fa fa-bank fa-5x"></i>
                                </div>
                                <div class="col-xs-9 text-right">
                                    <div class="huge">@ViewBag.ADVAMT</div>
                                    <div>Total HO Sales Value</div>
                                </div>
                            </div>
                        </div>
                        <a href="#">
                            <div class="panel-footer">
                                <span class="pull-left">View Details</span>
                                <span class="pull-right"><i class="fa fa-arrow-circle-right"></i></span>
                                <div class="clearfix"></div>
                            </div>
                        </a>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="panel panel-warning">
                        <div class="panel-heading">
                            <div class="row">
                                <div class="col-xs-3">
                                    <i class="fa fa-shopping-cart fa-5x"></i>
                                </div>
                                <div class="col-xs-9 text-right">
                                    <div class="huge">@ViewBag.AMRN</div>
                                    <div>Total No. of HO Sales Invoice</div>
                                </div>
                            </div>
                        </div>
                        <a href="#">
                            <div class="panel-footer">
                                <span class="pull-left">View Details</span>
                                <span class="pull-right"><i class="fa fa-arrow-circle-right"></i></span>
                                <div class="clearfix"></div>
                            </div>
                        </a>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 hide">
                    <div class="panel panel-info">
                        <div class="panel-heading">
                            <div class="row">
                                <div class="col-xs-3">
                                    <i class="fa fa-support fa-5x"></i>
                                </div>
                                <div class="col-xs-9 text-right">
                                    <div class="huge">@ViewBag.AMIN</div>
                                    <div>Total No. of MIN</div>
                                </div>
                            </div>
                        </div>
                        <a href="#">
                            <div class="panel-footer">
                                <span class="pull-left">View Details</span>
                                <span class="pull-right"><i class="fa fa-arrow-circle-right"></i></span>
                                <div class="clearfix"></div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-lg-3 col-md-6">
                    <div class="panel panel-primary">
                        <div class="panel-heading">
                            <div class="row">
                                <div class="col-xs-3">
                                    <i class="fa fa-shopping-cart fa-5x"></i>
                                </div>
                                <div class="col-xs-9 text-right">
                                    <div class="huge">@ViewBag.POAMT</div>
                                    <div>Total Purchase Order Value</div>
                                </div>
                            </div>
                        </div>
                        <a href="#">
                            <div class="panel-footer">
                                <span class="pull-left">View Details</span>
                                <span class="pull-right"><i class="fa fa-arrow-circle-right"></i></span>
                                <div class="clearfix"></div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        }
    }

    <!-- /.row -->
