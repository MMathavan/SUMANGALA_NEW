@model SSMI.Models.SalesInvoiceDetailsViewModel

<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
    <h4 class="modal-title">Sales Order Details</h4>
</div>

<div class="modal-body">
    <div class="row">
        <div class="col-md-12">
            <h4>Voucher</h4>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-3"><strong>Date</strong></div>
        <div class="col-md-3">@(Model.Voucher.VoucherDate.HasValue ? Model.Voucher.VoucherDate.Value.ToString("dd/MM/yyyy") : "")</div>
        <div class="col-md-3"><strong>Order No</strong></div>
        <div class="col-md-3">@Model.Voucher.VoucherNumber</div>
    </div>

    <div class="row" style="margin-top:6px;">
        <div class="col-md-3"><strong>Party Name</strong></div>
        <div class="col-md-9">@Model.Voucher.PartyName</div>
    </div>

    <div class="row" style="margin-top:6px;">
        <div class="col-md-3"><strong>GSTIN</strong></div>
        <div class="col-md-3">@Model.Voucher.PartyGSTIN</div>
        <div class="col-md-3"><strong>Total Amount</strong></div>
        <div class="col-md-3">@Model.Voucher.TotalAmount</div>
    </div>

    <div class="row" style="margin-top:6px;">
        <div class="col-md-3"><strong>Narration</strong></div>
        <div class="col-md-9">@Model.Voucher.Narration</div>
    </div>

    <div class="row" style="margin-top:15px;">
        <div class="col-md-12">
            <h4>Inventory</h4>
            <hr />
            <table class="table table-striped table-bordered" cellspacing="0" width="100%">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>HSN</th>
                        <th>Qty</th>
                        <th>Rate</th>
                        <th>Unit</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.InventoryLines)
                    {
                        <tr>
                            <td>@row.StockItemName</td>
                            <td>@row.HSNCode</td>
                            <td>@row.Quantity</td>
                            <td>@row.Rate</td>
                            <td>@row.UnitCode</td>
                            <td>@row.Amount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row" style="margin-top:15px;">
        <div class="col-md-12">
            <h4>Ledger</h4>
            <hr />
            <table class="table table-striped table-bordered" cellspacing="0" width="100%">
                <thead>
                    <tr>
                        <th>Ledger</th>
                        <th>Amount</th>
                        <th>Party</th>
                        <th>Tax</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.LedgerLines)
                    {
                        <tr>
                            <td>@row.LedgerName</td>
                            <td>@row.Amount</td>
                            <td>@(row.IsPartyLedger ? "Yes" : "No")</td>
                            <td>@(row.IsTaxLedger == 1 ? "Yes" : "No")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal-footer">
    <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
</div>
